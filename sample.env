# Sample environment variables for the INR ⇄ NPR Exchange Bot
# Copy this file to .env and fill in real values before running.

# Bot
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
ADMIN_IDS=123456789   # comma-separated admin Telegram user IDs

# Payment details
UPI_ID=business@upi
ESEWA_ID=esewa_merchant@123

# Exchange rates (defaults; admins can update in-bot)
INR_TO_NPR_RATE=1.60
NPR_TO_INR_RATE=0.625

# Limits & fees
MIN_EXCHANGE_AMOUNT=100
MAX_EXCHANGE_AMOUNT=100000
SERVICE_FEE_PERCENTAGE=2.5

# Referral and features
ENABLE_REFERRAL=True
REFERRAL_BONUS_PERCENT=1.0

# Database
DATABASE_PATH=database/exchange_bot.db

# Updater / remote config
UPSTREAM_REPO=https://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@github.com/SunilSharmaNP/exchanger
UPSTREAM_BRANCH=main
UPDATE_PKGS=True
MONGO_URI=mongodb+srv://saytdlp_db_user:sw6eTDVXW9UUfRzn@cluster0.5a1hvqu.mongodb.net/?appName=Cluster0

# Optional API / Owner
API_ID=1010723
