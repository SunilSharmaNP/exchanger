# Sample environment variables for the INR ⇄ NPR Exchange Bot
# Copy this file to .env and fill in real values before running.
# NEVER commit your real .env file to version control.

# ── Required ──────────────────────────────────────────────────────────────────
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
ADMIN_IDS=123456789              # comma-separated Telegram user IDs

# ── Payment details (admin can also update in-bot) ────────────────────────────
UPI_ID=business@upi
ESEWA_ID=esewa_merchant@123

# ── Exchange rates (admin can update in-bot) ──────────────────────────────────
# These are only used as initial DB seeds; rates are stored in the DB afterwards.
INR_TO_NPR_RATE=1.60
NPR_TO_INR_RATE=0.625

# ── Limits & fees ─────────────────────────────────────────────────────────────
MIN_EXCHANGE_AMOUNT=100
MAX_EXCHANGE_AMOUNT=100000
SERVICE_FEE_PERCENTAGE=2.5

# ── Referral ──────────────────────────────────────────────────────────────────
ENABLE_REFERRAL=True
REFERRAL_BONUS_PERCENT=1.0

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_PATH=database/exchange_bot.db

# ── Optional: auto-updater (leave blank to disable) ──────────────────────────
UPSTREAM_REPO=https://github.com/YOUR_USERNAME/YOUR_REPO
UPSTREAM_BRANCH=main
UPDATE_PKGS=True

# ── Telegram log channel ──────────────────────────────────────────────────────
# Create a private channel, add the bot as admin, then put the channel ID here.
# Format: -100XXXXXXXXXX  (negative number, starts with -100)
# Leave empty or unset to disable event logging.
LOG_CHANNEL_ID=-1001234567890

# ── Optional: Heroku / container ─────────────────────────────────────────────
# Set IN_DOCKER=1 when running inside a container so /restart exits the process
# and lets the supervisor restart it instead of os.execv.
IN_DOCKER=0
